# collector/.env (맥미니 로컬 전용 — 절대 커밋 금지. 루트 .gitignore 가 .env 차단).
# 랩탑 repo .env 의 값을 AirDrop/scp 로 안전하게 옮겨라(평문 메일 금지). spec §6.
#
# 큐 폴링 방식: collector 는 Supabase 로 아웃바운드만 한다 → 공개 노출·토큰·Tunnel 불필요.

# 필수 — seed_queue 폴링 + sentences/seed_sentences 적재(service role).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# 선택 — DB 마이그레이션(31_seed_queue.sql) 적용용 Management PAT(sbp_...). 없으면 대시보드로 수동 적용.
# SUPABASE_ACCESS_TOKEN=sbp_...

# 폴러 설정(선택 — 기본값 있음).
POLL_INTERVAL_MS=5000        # 큐 폴링 간격
POLL_BATCH=3                 # 한 폴에 처리할 책 수
COLLECTOR_DELAY_MS=2500      # 책 사이 딜레이(spec §7: 2~3초)

# 배치 prewarm 설정(선택).
PREWARM_LIMIT=150            # 인기책 상위 N권 큐잉
