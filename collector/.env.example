# collector/.env (맥미니 로컬 전용 — 절대 커밋 금지. 루트 .gitignore 가 .env 차단).
# 랩탑 repo .env 의 값을 AirDrop/scp 로 안전하게 옮겨라(평문 메일 금지). spec §6.

# seed_sentences 직접 적재용(service role). 본인 신뢰 기기라 무방.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# 워커 ↔ collector 인증(spec §6). 랜덤 문자열 직접 생성:
#   openssl rand -hex 32
# 같은 값을 워커 secret COLLECTOR_TOKEN 에도 등록(npx wrangler secret put COLLECTOR_TOKEN).
COLLECTOR_TOKEN=replace-with-openssl-rand-hex-32

# 데몬 설정(선택 — 기본값 있음).
COLLECTOR_PORT=8787
COLLECTOR_DELAY_MS=2500        # 요청 간 딜레이(spec §7: 2~3초)
COLLECTOR_TIMEOUT_MS=45000     # 단일 책 크롤 상한

# 주기 배치(prewarm) 설정(선택).
PREWARM_LIMIT=150             # 인기책 상위 N권 선충전
PREWARM_DELAY_MS=3000         # 책 간 딜레이(새벽·소량)
PREWARM_REFRESH_CAP=20        # #806 일일 재크롤 상한
